{
  "name": "Pokédex Voice Over",
  "id": "pokedex_voice_over",
  "version": "2.0.1",
  "author": "SilvertongueRED",
  "description": "Hear your Pokédex come alive! Reads every entry aloud in the voice of Dexter, the iconic anime narrator. Using an offline Fish-Speech voice-clone, so no internet needed after first setup. TTS server runs in a terminal in the background, and after first setup, startup of the mod is quick! Settings can be adjusted via the Mod Settings mod!",
  "tags": ["Audio", "QoL", "Fusion", "TTS"],
  "scripts": ["main.rb"],
  "settings": [
    {
      "key": "enabled",
      "label": "Enable Voice Over",
      "type": "toggle",
      "default": true
    },
    {
      "key": "volume",
      "label": "Voice Volume",
      "type": "slider",
      "default": 80,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "key": "mute_music",
      "label": "Mute Music in Pokédex",
      "type": "toggle",
      "default": true
    },
    {
      "key": "play_on_page_change",
      "label": "Re-read on Page Return",
      "type": "toggle",
      "default": false
    },
    {
      "key": "fish_speech_enabled",
      "label": "Fish-Speech Voice (Primary)",
      "type": "toggle",
      "default": true
    },
    {
      "key": "fish_speech_autostart",
      "label": "Auto-Start Fish-Speech Server",
      "type": "toggle",
      "default": true
    },
    {
      "key": "tts_enabled",
      "label": "TTS Fallback (Piper)",
      "type": "toggle",
      "default": true
    },
    {
      "key": "idle_prefetch",
      "label": "Idle Pre-Generation",
      "type": "toggle",
      "default": true
    }
  ]
}
